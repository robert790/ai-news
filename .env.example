# AI News · environment template
# Copy to .env and fill in real values

# LLM providers (at minimum, set GROQ_API_KEY)
# Get a free Groq key at https://console.groq.com/keys
GROQ_API_KEY=gsk-...
ANTHROPIC_API_KEY=sk-ant-...   # for premium tier deep analysis

# Optional: vector DB path (defaults to ./data/chroma)
CHROMA_PATH=./data/chroma

# App config
APP_LANGUAGE=ro               # ro = Romanian, en = English, both = bilingual
NEWS_CACHE_HOURS=24
PREMIUM_ENABLED=false         # toggle RAG premium tier